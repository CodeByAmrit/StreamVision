<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <title><%= dvr.dvr_name %> - Live Stream</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <link rel="stylesheet" href="/css/style.css?v=<%= appVersion %>" nonce="<%= nonce %>" />
    <!-- HLS.js -->
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest" nonce="<%= nonce %>"></script>

    <style>
      video {
        background: black;
      }
    </style>
  </head>

  <body class="bg-gray-950 text-white min-h-screen flex flex-col">
    <!-- ================= HEADER ================= -->
    <!-- Header -->
    <header
      class="flex flex-col sm:flex-row items-center justify-center sm:justify-between px-4 sm:px-8 py-4 sm:py-4 bg-gray-900 shadow-md gap-3 sm:gap-0"
    >
      <!-- Left: Logo + Title -->
      <div
        class="flex flex-col sm:flex-row items-center sm:space-x-4 space-y-2 sm:space-y-0 text-center sm:text-left w-full sm:w-auto"
      >
        <img
          src="/images/fci.png"
          alt="Logo"
          class="h-10 w-10 sm:h-12 sm:w-12 rounded-lg shadow-lg border border-gray-700 object-cover"
        />
        <div>
          <h1
            class="text-base sm:text-lg md:text-xl font-bold text-white tracking-wide leading-tight drop-shadow-sm"
          >
            <%= dvr.dvr_name %> - Live Camera Streams
          </h1>
          <p
            class="text-[11px] sm:text-xs md:text-sm text-gray-400 font-medium tracking-wider uppercase mt-1 flex items-center justify-center sm:justify-start"
          >
            <i class="fas fa-map-marker-alt text-red-500 mr-1.5"></i>
            <%= dvr.location_name %>
          </p>
        </div>
      </div>

      <!-- Desktop: Support Button -->
      <a
        href="https://cctvcameralive.in/#contact"
        class="hidden sm:flex bg-gradient-to-r from-blue-500 to-cyan-500 text-white font-semibold px-5 py-2 rounded-xl shadow-md hover:from-blue-600 hover:to-cyan-600 transition-all duration-300 items-center space-x-2 z-50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M18.364 5.636a9 9 0 11-12.728 0m6.364 4.364v4m0 4h.01"
          />
        </svg>
        <span>Support</span>
      </a>
    </header>

    <!-- Mobile: Fixed Support Button -->
    <a
      href="https://cctvcameralive.in/#contact"
      class="sm:hidden fixed bottom-6 right-4 py-3 px-6 bg-gradient-to-r from-blue-500 to-cyan-500 text-white font-semibold text-sm rounded-full shadow-[0_4px_14px_rgba(59,130,246,0.39)] hover:shadow-[0_6px_20px_rgba(59,130,246,0.23)] hover:-translate-y-1 transition-all duration-300 z-50 flex items-center justify-center gap-2"
    >
      <i class="fas fa-headset text-lg"></i>
      Support
    </a>

    <!-- ================= GRID ================= -->
    <main
      id="grid"
      class="flex-1 p-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 pb-24"
    >
      <!-- Cameras injected dynamically -->
    </main>

    <!-- ================= FOOTER ================= -->
    <footer class="bg-gray-900 text-center py-4 text-xs text-gray-500 border-t border-gray-800">
      <div class="flex items-center justify-center gap-2 mb-1">
        <img src="/images/netwon.svg" alt="Netwon" class="h-4 w-4 opacity-70" />
        <span class="font-medium">Netwon Team</span>
      </div>
      © <%= new Date().getFullYear() %> StreamVision <%= appVersion %>
    </footer>

    <!-- ================= CLIENT JS ================= -->
    <script nonce="<%= nonce %>">
      /* =====================================================
       HELPERS
    ===================================================== */
      function getDvrId() {
        const parts = window.location.pathname.split("/");
        return parts[parts.length - 1];
      }

      function log(...args) {
        console.log("[DVR]", ...args);
      }

      /* =====================================================
       HLS VIDEO PLAYER
    ===================================================== */
      const RETRY_INTERVAL = 500;
      const MAX_RETRIES = 30;
      const hlsInstances = [];

      function tryLoadHlsStream(video, cameraId, retriesLeft = MAX_RETRIES) {
        if (!isTabActive) return;

        fetch(`/api/public/camera/${cameraId}/hls`)
          .then((res) => res.json())
          .then((data) => {
            if (data.error) {
              throw new Error(data.error);
            }

            const source = data.hlsUrl;

            if (Hls.isSupported()) {
              const hls = new Hls({
                manifestLoadingTimeOut: 2000,
                manifestLoadingMaxRetry: 1,
                levelLoadingTimeOut: 2000,
                levelLoadingMaxRetry: 1,
                lowLatencyMode: true,
              });
              hlsInstances.push(hls);
              hls.loadSource(source);
              hls.attachMedia(video);
              hls.on(Hls.Events.MANIFEST_PARSED, () => {
                video.play().catch(() => {});
              });
              hls.on(Hls.Events.ERROR, function (event, data) {
                if (data.fatal) {
                  switch (data.type) {
                    case Hls.ErrorTypes.NETWORK_ERROR:
                      hls.destroy();
                      handleRetry();
                      break;
                    case Hls.ErrorTypes.MEDIA_ERROR:
                      hls.recoverMediaError();
                      break;
                    default:
                      hls.destroy();
                      handleRetry();
                      break;
                  }
                }
              });
            } else if (video.canPlayType("application/vnd.apple.mpegurl")) {
              video.src = source;
              video.addEventListener("loadedmetadata", () => {
                video.play().catch(() => {});
              });
              video.addEventListener("error", () => {
                handleRetry();
              });
            }
          })
          .catch((err) => {
            console.error(`Error for cam ${cameraId}:`, err);
            handleRetry();
          });

        function handleRetry() {
          if (retriesLeft > 0 && isTabActive) {
            setTimeout(() => tryLoadHlsStream(video, cameraId, retriesLeft - 1), RETRY_INTERVAL);
          }
        }
      }

      /* =====================================================
       LOAD CAMERAS
    ===================================================== */
      async function loadCameras() {
        const dvrId = getDvrId();
        log("Loading DVR", dvrId);

        const res = await fetch(`/api/dvr/${dvrId}/cameras`);
        const cameras = await res.json();

        const grid = document.getElementById("grid");

        // Dynamic Grid Columns based on camera count
        const count = cameras.length;
        // Base classes: Center the grid and provide tighter spacing
        grid.className = "flex-1 p-2 sm:p-4 grid gap-3 mx-auto w-full max-w-[1920px]";

        if (count === 1) {
          // Single camera: Don't let it span more than ~1024px to prevent massive black bars
          grid.classList.add("grid-cols-1", "max-w-4xl");
        } else if (count === 2) {
          // Dual cameras: Max width around ~1280px (640px each)
          grid.classList.add("grid-cols-1", "md:grid-cols-2", "max-w-6xl");
        } else if (count <= 4) {
          grid.classList.add("grid-cols-1", "sm:grid-cols-2", "max-w-7xl");
        } else {
          // Many cameras: Allow a wider layout but still constrained for ultra-wide monitors
          grid.classList.add("grid-cols-2", "md:grid-cols-3", "lg:grid-cols-4");
        }

        cameras.forEach((cam, i) => {
          const wrapper = document.createElement("div");
          wrapper.className =
            "relative bg-black rounded-lg overflow-hidden border border-gray-800 shadow-xl";

          wrapper.innerHTML = `
            <video class="w-full h-auto bg-black block" muted autoplay playsinline controls></video>
          `;

          grid.appendChild(wrapper);

          const video = wrapper.querySelector("video");
          tryLoadHlsStream(video, cam.id);
        });
      }

      /* =====================================================
       INIT
    ===================================================== */
      let isTabActive = true;

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          isTabActive = false;
          log("Tab hidden - killing active streams");
          // 1. Destroy all HLS.js instances
          while (hlsInstances.length > 0) {
            const hls = hlsInstances.pop();
            if (hls) hls.destroy();
          }
          // 2. Pause all video elements to be sure
          document.querySelectorAll("video").forEach((v) => v.pause());
        } else {
          log("Tab active - refreshing page to get latest content");
          window.location.reload();
        }
      });

      document.addEventListener("DOMContentLoaded", loadCameras);
    </script>
  </body>
</html>
