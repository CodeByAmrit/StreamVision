<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes"
    />
    <title>RTSP Live Stream Viewer | StreamVision</title>
    <meta
      name="description"
      content="StreamVision - View your RTSP camera feeds live with a powerful, modern, and secure web viewer."
    />
    <meta
      name="keywords"
      content="live cctv camera feed, watch security camera online, ip camera live stream, remote video surveillance viewer, public webcams, real-time monitoring, rtsp hls stream player"
    />
    <meta name="author" content="Amrit, Developer of StreamVision" />
    <link rel="canonical" href="https://cctvcameralive.in/" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content="StreamVision | RTSP Live CCTV Viewer" />
    <meta
      property="og:description"
      content="Real-time RTSP CCTV camera streaming using HLS and analytics."
    />
    <meta property="og:image" content="https://cctvcameralive.in/images/banner.svg" />
    <meta property="og:url" content="https://cctvcameralive.in" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="StreamVision | RTSP Live CCTV Viewer" />
    <meta
      name="twitter:description"
      content="Real-time RTSP CCTV camera streaming using HLS and analytics."
    />
    <meta name="twitter:image" content="https://cctvcameralive.in/images/banner.svg" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css?v=<%= appVersion %>" nonce="<%= nonce %>" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      nonce="<%= nonce %>"
    />
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
      defer
      nonce="<%= nonce %>"
    ></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
      defer
      nonce="<%= nonce %>"
    ></script>
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest" defer nonce="<%= nonce %>"></script>
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <style nonce="<%= nonce %>">
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap");
      * {
        font-family: "Inter", sans-serif;
      }
      .gradient-text {
        background: linear-gradient(to right, #63b3ed, #3182ce);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .btn-gradient {
        background: linear-gradient(to right, #63b3ed, #3182ce);
        transition: all 0.3s ease;
      }
      .btn-gradient:hover {
        background: linear-gradient(to right, #3182ce, #2c5282);
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(49, 130, 206, 0.3);
      }
      .btn-gradient:active {
        transform: translateY(0);
      }
      .card-hover {
        transition: all 0.3s ease;
      }
      .card-hover:hover {
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
      }
      .loader {
        border-top-color: #3182ce;
        -webkit-animation: spinner 1.5s linear infinite;
        animation: spinner 1.5s linear infinite;
      }
      @-webkit-keyframes spinner {
        0% {
          -webkit-transform: rotate(0deg);
        }
        100% {
          -webkit-transform: rotate(360deg);
        }
      }
      @keyframes spinner {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }
      .tech-icon {
        transition: all 0.3s ease;
      }
      .tech-icon:hover {
        transform: scale(1.1) rotate(5deg);
      }
      .shadow-glow {
        box-shadow: 0 0 20px rgba(99, 179, 237, 0.2);
      }
      .shadow-glow:hover {
        box-shadow: 0 0 30px rgba(99, 179, 237, 0.3);
      }
      .border-glow {
        border-color: rgba(99, 179, 237, 0.3);
      }
      .border-glow:hover {
        border-color: rgba(99, 179, 237, 0.6);
      }
      .bg-grid-pattern {
        background-image:
          linear-gradient(rgba(99, 179, 237, 0.1) 1px, transparent 1px),
          linear-gradient(90deg, rgba(99, 179, 237, 0.1) 1px, transparent 1px);
        background-size: 50px 50px;
      }
      .hero-gradient {
        background: linear-gradient(
          135deg,
          rgba(99, 179, 237, 0.1) 0%,
          rgba(49, 130, 206, 0.05) 100%
        );
      }
      .pulse-animation {
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0% {
          box-shadow: 0 0 0 0 rgba(99, 179, 237, 0.7);
        }
        70% {
          box-shadow: 0 0 0 10px rgba(99, 179, 237, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(99, 179, 237, 0);
        }
      }
      .slide-down {
        animation: slideDown 0.5s ease forwards;
      }
      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* ✦ SMALL-SCREEN OPTIMIZATIONS (preserving everything) ✦ */
      @media (max-width: 640px) {
        .max-w-7xl {
          padding-left: 1rem;
          padding-right: 1rem;
        }
        h1 {
          font-size: 2rem !important;
          line-height: 1.2 !important;
        }
        h2 {
          font-size: 1.75rem !important;
          line-height: 1.3 !important;
        }
        .gradient-text {
          word-break: break-word;
        }
        .grid {
          gap: 1rem;
        }
        .p-8 {
          padding: 1.25rem;
        }
        .px-4 {
          padding-left: 1rem;
          padding-right: 1rem;
        }
        .py-16 {
          padding-top: 3rem;
          padding-bottom: 3rem;
        }
        .text-5xl {
          font-size: 2.5rem !important;
        }
        .text-4xl {
          font-size: 2rem !important;
        }
        .hero-gradient .inline-flex {
          flex-wrap: wrap;
          justify-content: center;
        }
        .hero-gradient .inline-flex a {
          white-space: normal;
        }
        #videoPlaceholder p br {
          display: none;
        }
        #videoPlaceholder p {
          max-width: 280px;
          margin-left: auto;
          margin-right: auto;
        }
        .tech-icon {
          margin-left: auto;
          margin-right: auto;
        }
        footer .flex-col.md\:flex-row {
          flex-direction: column;
          text-align: center;
        }
        footer .flex.space-x-6 {
          flex-wrap: wrap;
          justify-content: center;
          gap: 1rem;
        }
      }
      @media (max-width: 480px) {
        header .flex.items-center.space-x-2.sm\:space-x-4 {
          gap: 0.5rem;
        }
        header a[href="#contact"] {
          display: none;
        } /* hidden via sm:flex, but ensure it's gone */
        .btn-gradient.px-3.py-1\.5 {
          font-size: 0.75rem;
          padding-left: 0.6rem;
          padding-right: 0.6rem;
        }
        .w-8.h-8.sm\:w-10.sm\:h-10 {
          width: 2rem;
          height: 2rem;
        }
        .rounded-xl.bg-gradient-to-br.from-\[\#63b3ed\].to-\[\#3182ce\] {
          width: 2rem;
          height: 2rem;
        }
        img[alt="Logo"] {
          width: 1.25rem;
          height: 1.25rem;
        }
        .text-base.sm\:text-xl.font-bold {
          font-size: 0.95rem;
        }
        .text-\[10px\].sm\:text-xs {
          font-size: 0.6rem;
        }
      }
    </style>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-800 dark:text-gray-100 min-h-screen">
    <!-- Header -->
    <header
      class="sticky top-0 z-40 w-full bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-blue-100 dark:border-gray-800"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14 sm:h-16">
          <a href="/" class="flex items-center space-x-2 sm:space-x-3">
            <div
              class="w-8 h-8 sm:w-10 sm:h-10 rounded-xl bg-gradient-to-br from-[#63b3ed] to-[#3182ce] flex items-center justify-center shrink-0"
            >
              <img
                src="/images/netwon.svg"
                alt="Logo"
                class="w-6 h-6 sm:w-8 sm:h-8 rounded-xl object-contain"
              />
            </div>
            <div class="flex flex-col justify-center">
              <span class="text-base sm:text-xl font-bold gradient-text leading-tight">
                Netwon Team
              </span>
              <p class="text-[10px] sm:text-xs text-gray-500 dark:text-gray-400 leading-tight">
                Presents StreamVision
              </p>
            </div>
          </a>
          <div class="flex items-center space-x-2 sm:space-x-4 shrink-0">
            <button
              id="theme-toggle"
              class="p-1.5 sm:p-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              <i class="fas fa-moon dark:hidden text-sm sm:text-base"></i>
              <i class="fas fa-sun hidden dark:inline text-sm sm:text-base"></i>
            </button>
            <a
              href="#contact"
              class="hidden sm:inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              <i class="fas fa-envelope mr-2"></i>
              Contact Us
            </a>
            <a
              href="/login"
              class="btn-gradient text-white font-medium rounded-lg sm:rounded-xl px-3 py-1.5 sm:px-5 sm:py-2.5 text-xs sm:text-sm inline-flex items-center shadow-sm whitespace-nowrap"
            >
              <i class="fas fa-sign-in-alt mr-1.5 sm:mr-2"></i>
              Admin Login
            </a>
          </div>
        </div>
      </div>
    </header>

    <main class="overflow-x-hidden">
      <!-- Hero Section (optimized stacking for small screens) -->
      <section class="relative py-12 sm:py-20 lg:py-24 hero-gradient">
        <div class="absolute inset-0 bg-grid-pattern"></div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <div class="text-center mb-8 sm:mb-12">
            <div
              class="inline-flex flex-wrap items-center justify-center gap-2 mb-6 sm:mb-8 px-3 py-2 bg-blue-50 dark:bg-blue-900/30 rounded-full border border-blue-100 dark:border-blue-800"
            >
              <span
                class="text-xs bg-gradient-to-r from-[#63b3ed] to-[#3182ce] text-white px-3 py-1 rounded-full"
              >
                <i class="fas fa-rocket mr-1"></i>
                New
              </span>
              <a
                href="/updates"
                class="text-xs sm:text-sm font-medium text-gray-700 dark:text-gray-300"
              >
                StreamVision <%= appVersion %> is live! Enhanced streaming 🚀
              </a>
            </div>
            <h1 class="text-3xl sm:text-5xl lg:text-6xl font-bold mb-3 sm:mb-6 leading-tight">
              <span class="block">Live</span>
              <span class="gradient-text">RTSP Stream Viewer</span>
            </h1>
            <p
              class="text-base sm:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto mb-6 sm:mb-10 px-2"
            >
              Securely view your RTSP camera feeds in real-time with our powerful web-based
              streaming platform
            </p>
          </div>

          <!-- Streaming Interface (stacked vertically for small screens) -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-stretch">
            <!-- Input Card -->
            <div
              class="h-full flex flex-col bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-5 sm:p-6 lg:p-8 border border-blue-100 dark:border-gray-700 card-hover"
            >
              <div class="flex items-center mb-5">
                <div
                  class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-100 to-blue-50 dark:from-blue-900/30 dark:to-blue-800/20 flex items-center justify-center mr-4 shrink-0"
                >
                  <i class="fas fa-link text-[#3182ce] dark:text-blue-400 text-xl"></i>
                </div>
                <div>
                  <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white">
                    Stream Input
                  </h3>
                  <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">
                    Enter your RTSP URL to begin
                  </p>
                </div>
              </div>
              <div class="space-y-4 flex-grow flex flex-col justify-center">
                <div>
                  <label
                    for="rtspInput"
                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                  >
                    <i class="fas fa-camera mr-2"></i>
                    RTSP Stream URL
                  </label>
                  <input
                    type="text"
                    id="rtspInput"
                    class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700 border border-blue-200 dark:border-gray-600 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-gray-900 dark:text-white transition-all"
                    placeholder="rtsp://username:password@ip:port/stream"
                  />
                </div>
                <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 pt-4 mt-auto">
                  <button
                    id="playBtn"
                    class="btn-gradient text-white font-medium rounded-xl px-4 py-2.5 sm:px-6 sm:py-3.5 flex-1 inline-flex items-center justify-center text-sm sm:text-base"
                  >
                    <i class="fas fa-play mr-2"></i>
                    Start Stream
                  </button>
                  <button
                    id="stopBtn"
                    class="hidden bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 font-medium rounded-xl px-4 py-2.5 sm:px-6 sm:py-3.5 flex-1 inline-flex items-center justify-center hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors text-sm sm:text-base"
                  >
                    <i class="fas fa-stop mr-2"></i>
                    Stop Stream
                  </button>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400 pt-2 text-center mt-2">
                  <i class="fas fa-info-circle mr-1"></i>
                  Ensure your camera supports RTSP and is accessible
                </div>
              </div>
            </div>

            <!-- Video Preview Card (min-height adjusted for small screens) -->
            <div
              class="h-full flex flex-col bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-blue-100 dark:border-gray-700 overflow-hidden"
            >
              <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-blue-50 dark:border-gray-700">
                <div class="flex items-center justify-between">
                  <div class="flex items-center">
                    <div
                      class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-100 to-blue-50 dark:from-blue-900/30 dark:to-blue-800/20 flex items-center justify-center mr-3 shrink-0"
                    >
                      <i class="fas fa-eye text-[#3182ce] dark:text-blue-400"></i>
                    </div>
                    <div>
                      <h3 class="text-base sm:text-lg font-bold text-gray-900 dark:text-white">
                        Live Preview
                      </h3>
                      <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">
                        Stream output
                      </p>
                    </div>
                  </div>
                  <div class="flex items-center space-x-2">
                    <div class="w-3 h-3 rounded-full bg-green-500 animate-pulse"></div>
                    <span class="text-sm text-green-600 dark:text-green-400">Live</span>
                  </div>
                </div>
              </div>
              <!-- Content Area (height adapts) -->
              <div
                class="flex-grow flex flex-col relative bg-gray-900 overflow-hidden min-h-[260px] sm:min-h-[300px]"
              >
                <div
                  id="videoContainer"
                  class="hidden absolute inset-0 w-full h-full flex flex-col"
                >
                  <div
                    id="loader"
                    class="hidden absolute inset-0 flex items-center justify-center z-10 bg-gray-900/90"
                  >
                    <div class="text-center px-4">
                      <div
                        class="loader ease-linear rounded-full border-4 border-t-4 border-blue-500 h-12 w-12 mx-auto mb-4"
                      ></div>
                      <p class="text-blue-400 font-medium">Initializing stream...</p>
                      <p class="text-sm text-gray-400 mt-1">This may take a few moments</p>
                    </div>
                  </div>
                  <video
                    id="videoPlayer"
                    width="100%"
                    controls
                    class="w-full h-full object-contain hidden"
                    poster="https://images.unsplash.com/photo-1513475382585-d06e58bcb0e0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                  ></video>
                </div>
                <div
                  id="videoPlaceholder"
                  class="absolute inset-0 bg-gradient-to-br from-gray-800 to-gray-900 flex flex-col items-center justify-center p-4 sm:p-6"
                >
                  <div
                    class="w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-gradient-to-br from-blue-900/50 to-blue-800/30 flex items-center justify-center mb-4 sm:mb-6 border-2 border-blue-700/30"
                  >
                    <i class="fas fa-video text-blue-400 text-2xl sm:text-3xl"></i>
                  </div>
                  <h4 class="text-lg sm:text-xl font-bold text-white mb-2 text-center">
                    Stream Preview
                  </h4>
                  <p class="text-xs sm:text-sm text-gray-400 text-center max-w-sm">
                    Enter an RTSP URL and click "Start Stream" to view your live camera feed here
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Technology Stack Section (cards wrap nicely) -->
      <section class="py-12 sm:py-20 lg:py-24 bg-white dark:bg-gray-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10 sm:mb-12">
            <span
              class="inline-flex items-center px-4 py-2 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400 text-sm font-medium mb-4"
            >
              <i class="fas fa-microchip mr-2"></i>
              Technology Stack
            </span>
            <h2 class="text-2xl sm:text-4xl lg:text-5xl font-bold mb-3 sm:mb-6">
              Powered by
              <span class="gradient-text">Modern Technology</span>
            </h2>
            <p class="text-base sm:text-lg text-gray-600 dark:text-gray-400 max-w-3xl mx-auto px-4">
              StreamVision leverages cutting-edge open-source technologies for exceptional
              performance and reliability
            </p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-12">
            <div
              class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-5 sm:p-6 border border-blue-100 dark:border-gray-700 card-hover text-center"
            >
              <div
                class="w-16 h-16 rounded-xl bg-gradient-to-br from-blue-100 to-blue-50 dark:from-blue-900/30 dark:to-blue-800/20 flex items-center justify-center mb-6 mx-auto tech-icon"
              >
                <i class="fas fa-video text-[#3182ce] dark:text-blue-400 text-2xl"></i>
              </div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">FFmpeg</h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm">
                High-performance video processing and transcoding
              </p>
            </div>
            <div
              class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-5 sm:p-6 border border-blue-100 dark:border-gray-700 card-hover text-center"
            >
              <div
                class="w-16 h-16 rounded-xl bg-gradient-to-br from-blue-100 to-blue-50 dark:from-blue-900/30 dark:to-blue-800/20 flex items-center justify-center mb-6 mx-auto tech-icon"
              >
                <i class="fas fa-broadcast-tower text-[#3182ce] dark:text-blue-400 text-2xl"></i>
              </div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">HLS Protocol</h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm">
                Adaptive streaming for smooth playback across devices
              </p>
            </div>
            <div
              class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-5 sm:p-6 border border-blue-100 dark:border-gray-700 card-hover text-center"
            >
              <div
                class="w-16 h-16 rounded-xl bg-gradient-to-br from-blue-100 to-blue-50 dark:from-blue-900/30 dark:to-blue-800/20 flex items-center justify-center mb-6 mx-auto tech-icon"
              >
                <i class="fab fa-node-js text-[#3182ce] dark:text-blue-400 text-2xl"></i>
              </div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Node.js</h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm">
                Scalable backend runtime for real-time processing
              </p>
            </div>
            <div
              class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-5 sm:p-6 border border-blue-100 dark:border-gray-700 card-hover text-center"
            >
              <div
                class="w-16 h-16 rounded-xl bg-gradient-to-br from-blue-100 to-blue-50 dark:from-blue-900/30 dark:to-blue-800/20 flex items-center justify-center mb-6 mx-auto tech-icon"
              >
                <i class="fas fa-bolt text-[#3182ce] dark:text-blue-400 text-2xl"></i>
              </div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Express.js</h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm">
                Fast and minimalist web application framework
              </p>
            </div>
          </div>
          <div
            class="bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/30 dark:to-blue-800/20 rounded-2xl p-6 sm:p-8 border border-blue-200 dark:border-blue-800"
          >
            <div class="flex flex-col lg:flex-row items-center justify-between gap-4">
              <div class="text-center lg:text-left">
                <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-2">
                  Open Source Community
                </h3>
                <p class="text-sm sm:text-base text-gray-700 dark:text-gray-300">
                  StreamVision is an open-source project. Join our community to contribute, suggest
                  features, or report issues.
                </p>
