<%- include('./partials/header.ejs',{title: "Add DVR"}) %> <%- include('./partials/topMenu.ejs',
{title: "Add DVR", user: user}) %> <%- include('./partials/navbar.ejs', {activePage: 'dvr'}) %>

<section class="p-4 sm:ml-64 dark:bg-gray-900 dark:text-white min-h-screen">
  <div class="max-w-xl mx-auto mt-20 bg-white dark:bg-gray-800 shadow-sm border border-blue-100 dark:border-gray-700 rounded-xl p-5">
    <h2 class="text-lg font-bold mb-4 text-center text-gray-800 dark:text-white">
      Add New DVR / Location
    </h2>

    <form action="/dvr/add" method="POST" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <!-- DVR Name -->
      <div>
        <label
          for="dvr_name"
          class="block mb-1.5 text-sm font-medium text-gray-700 dark:text-gray-300"
        >
          DVR Name
        </label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="fas fa-server text-gray-400"></i>
          </div>
          <input
            type="text"
            id="dvr_name"
            name="dvr_name"
            required
            placeholder="e.g. Main DVR 01"
            class="w-full pl-10 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>
      </div>

      <!-- Location Dropdown -->
      <div>
        <label
          for="location_id"
          class="block mb-1.5 text-sm font-medium text-gray-700 dark:text-gray-300"
        >
          Location
        </label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="fas fa-map-marker-alt text-gray-400"></i>
          </div>
          <select
            id="location_id"
            name="location_id"
            required
            class="w-full pl-10 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <option value="" disabled selected>Select Location</option>
            <% locations.forEach(location => { %>
            <option value="<%= location.id %>"><%= location.location_name %></option>
            <% }) %>
            <option value="new" class="font-semibold text-blue-600 dark:text-blue-400">➕ Add New Location</option>
          </select>
        </div>
      </div>

      <!-- New Location Input (initially hidden) -->
      <div id="newLocationField" class="hidden p-4 rounded-lg bg-blue-50/50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800/50">
        <label
          for="new_location"
          class="block mb-1.5 text-sm font-medium text-blue-800 dark:text-blue-300"
        >
          New Location Name
        </label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="fas fa-map-pin text-blue-400"></i>
          </div>
          <input
            type="text"
            id="new_location"
            name="new_location"
            placeholder="Type new location name..."
            class="w-full pl-10 pr-3 py-2 text-sm border border-blue-200 dark:border-blue-700 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 shadow-sm"
          />
        </div>
      </div>

      <!-- Submit -->
      <div class="flex justify-end pt-2">
        <button
          type="submit"
          class="px-5 py-2 text-sm font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 dark:focus:ring-blue-800 transition-all inline-flex items-center"
        >
          <i class="fas fa-save mr-2"></i>
          Save DVR
        </button>
      </div>
    </form>
  </div>
</section>

<script nonce="<%= nonce %>">
  const locationSelect = document.getElementById("location_id");
  const newLocationField = document.getElementById("newLocationField");

  locationSelect.addEventListener("change", function () {
    if (this.value === "new") {
      newLocationField.classList.remove("hidden");
      document.getElementById("new_location").required = true;
    } else {
      newLocationField.classList.add("hidden");
      document.getElementById("new_location").required = false;
    }
  });
</script>

<%- include('./partials/footer.ejs') %>
