<!-- Main Content -->
<main class="p-4 sm:ml-64 mt-16 min-h-screen bg-gray-50/50 dark:bg-gray-900/50">
  
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-4">
    <!-- Welcome Banner (Shrunk) -->
    <div class="lg:col-span-2">
      <div class="bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/10 rounded-xl p-4 border border-blue-200 dark:border-blue-800 h-full flex flex-col justify-center">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
          <div>
            <h2 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-1">
              Welcome back, <span class="gradient-text">Admin!</span>
            </h2>
            <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">
              Monitor your live streams and manage equipment.
            </p>
          </div>
          <div class="flex items-center space-x-3">
            <div class="text-right hidden md:block">
              <div class="flex items-center">
                <div class="w-2 h-2 rounded-full bg-green-500 mr-2 animate-pulse"></div>
                <p class="text-sm font-bold text-green-600 dark:text-green-400">
                  Systems Operational
                </p>
              </div>
            </div>
            <button class="btn-gradient text-white font-medium rounded-lg px-4 py-2 text-xs inline-flex items-center whitespace-nowrap">
              <i class="fas fa-play mr-2"></i> Quick Stream
            </button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Top Quick Actions Panel -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 flex flex-col justify-center">
      <div class="grid grid-cols-2 gap-2">
        <a href="/camera/add" class="flex flex-col items-center justify-center p-2 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors border border-blue-100 dark:border-blue-800/50">
          <i class="fas fa-video mb-1 text-lg"></i>
          <span class="text-xs font-semibold">Add Camera</span>
        </a>
        <a href="/dvr/add" class="flex flex-col items-center justify-center p-2 rounded-lg bg-purple-50 dark:bg-purple-900/20 text-purple-700 dark:text-purple-400 hover:bg-purple-100 dark:hover:bg-purple-900/40 transition-colors border border-purple-100 dark:border-purple-800/50">
          <i class="fas fa-server mb-1 text-lg"></i>
          <span class="text-xs font-semibold">Add DVR</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Stats Overview -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
    <!-- Total Locations Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 card-hover">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Locations</p>
        <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center">
          <i class="fas fa-building text-blue-600 dark:text-blue-400 text-sm"></i>
        </div>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= total_dvrs || 0 %></h3>
      <div class="flex items-center text-xs space-x-2">
        <span class="text-green-600 dark:text-green-400 font-medium bg-green-50 dark:bg-green-900/30 px-1.5 py-0.5 rounded"><i class="fas fa-arrow-up mr-1 invisible"></i><%= activeDvrs.length %> Online</span>
        <span class="text-red-500 dark:text-red-400"><%= total_dvrs - activeDvrs.length %> Offline</span>
      </div>
    </div>

    <!-- Total Cameras Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 card-hover">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Cameras</p>
        <div class="w-8 h-8 rounded-lg bg-purple-50 dark:bg-purple-900/30 flex items-center justify-center">
          <i class="fas fa-video text-purple-600 dark:text-purple-400 text-sm"></i>
        </div>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= total_cameras || 0 %></h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 truncate">Total connected devices</p>
    </div>

    <!-- Live Streams Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 card-hover">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Live Streams</p>
        <div class="w-8 h-8 rounded-lg bg-green-50 dark:bg-green-900/30 flex items-center justify-center">
           <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse absolute"></div>
        </div>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= active_streams || 0 %></h3>
      <p class="text-xs text-green-600 dark:text-green-400 font-medium">Streaming active</p>
    </div>

    <!-- Memory Usage Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 card-hover">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Memory Used</p>
        <div class="w-8 h-8 rounded-lg bg-orange-50 dark:bg-orange-900/30 flex items-center justify-center">
          <i class="fas fa-memory text-orange-600 dark:text-orange-400 text-sm"></i>
        </div>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= systemStats.memoryUsagePercent %>%</h3>
      <div class="w-full bg-gray-200 rounded-full h-1.5 dark:bg-gray-700 mt-1">
        <div class="bg-gradient-to-r from-orange-400 to-red-500 h-1.5 rounded-full" style="width: <%= systemStats.memoryUsagePercent %>%"></div>
      </div>
    </div>
  </div>

  <!-- Two Column Layout Area -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
    <!-- Live DVRs List -->
    <div class="xl:col-span-2">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 overflow-hidden h-full">
        <!-- Header -->
        <div class="px-5 py-3 border-b border-blue-50 dark:border-gray-700 flex items-center justify-between bg-gray-50/50 dark:bg-gray-800/50">
          <h3 class="text-sm font-bold text-gray-900 dark:text-white tracking-wide uppercase">Active DVR Streams</h3>
          <a href="/dvr" class="text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-semibold bg-blue-50 dark:bg-blue-900/30 px-2 py-1 rounded">View All</a>
        </div>

        <!-- DVRs List -->
        <div class="divide-y divide-gray-100 dark:divide-gray-700/50">
          <% if (activeDvrs.length > 0) { %> 
            <% activeDvrs.slice(0, 5).forEach(dvr => { %> <!-- Show up to 5 on dashboard -->
            <a href="/public/dvr/<%= dvr.id %>" target="_blank" class="block hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors group">
              <div class="px-5 py-3 flex items-center justify-between">
                <div class="flex items-center space-x-3">
                  <div class="relative">
                    <div class="w-10 h-10 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center text-blue-600 dark:text-blue-400 group-hover:bg-blue-100 dark:group-hover:bg-blue-900/40 transition-colors">
                      <i class="fas fa-server"></i>
                    </div>
                    <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-green-500 border-2 border-white dark:border-gray-800"></div>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white text-sm"><%= dvr.dvr_name %></h4>
                    <p class="text-xs text-gray-500 dark:text-gray-400 truncate max-w-[150px] sm:max-w-xs"><i class="fas fa-map-marker-alt mr-1 opacity-70"></i><%= dvr.location_name %></p>
                  </div>
                </div>
                <div class="flex items-center space-x-2 sm:space-x-4">
                  <div class="text-right hidden sm:block">
                     <p class="text-xs font-medium text-gray-900 dark:text-white"><%= dvr.activeCameraCount %> cams</p>
                     <p class="text-[10px] text-green-600 dark:text-green-400 uppercase font-semibold tracking-wider">Live View</p>
                  </div>
                  <i class="fas fa-chevron-right text-gray-300 dark:text-gray-600 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors text-sm"></i>
                </div>
              </div>
            </a>
            <% }); %> 
          <% } else { %>
            <div class="px-6 py-10 text-center flex flex-col items-center justify-center">
              <div class="w-12 h-12 rounded-full bg-gray-50 dark:bg-gray-800 border border-dashed border-gray-300 dark:border-gray-600 flex items-center justify-center mb-3">
                <i class="fas fa-video-slash text-gray-400"></i>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">No active streams to display.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Right Column Metrics -->
    <div class="space-y-4">
      <!-- System Health Compact -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-5">
        <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wide mb-4">System Health</h3>
        <div class="space-y-4">
          <div>
            <div class="flex items-center justify-between mb-1.5 text-xs">
              <span class="font-medium text-gray-600 dark:text-gray-400">CPU Load (1m)</span>
              <span class="font-bold text-gray-900 dark:text-white text-right"><%= systemStats.serverLoadPercent %>%</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5 dark:bg-gray-700 overflow-hidden">
              <div class="bg-blue-500 h-1.5 rounded-full transition-all duration-500" style="width: <%= systemStats.serverLoadPercent %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5 text-xs">
              <span class="font-medium text-gray-600 dark:text-gray-400">Server Uptime</span>
              <span class="font-bold text-green-500 dark:text-green-400 text-right"><%= systemStats.uptimeDisplay %></span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5 dark:bg-gray-700">
              <div class="bg-green-500 h-1.5 rounded-full" style="width: 100%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5 text-xs">
              <span class="font-medium text-gray-600 dark:text-gray-400">Node Process Memory</span>
              <span class="font-bold text-orange-500 dark:text-orange-400 text-right"><%= systemStats.processMemoryMb %> MB</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5 dark:bg-gray-700 overflow-hidden">
              <!-- Using a static visual width for process memory as it's hard to get a "max" value inherently -->
              <div class="bg-orange-400 h-1.5 rounded-full" style="width: 45%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Analysis Graph (Dynamic Based on Cameras/Streams) -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-5 flex-1 hidden xl:block">
        <div class="flex items-center justify-between mb-4">
           <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wide">Traffic (Active vs Max)</h3>
           <a href="/analytics" class="text-[10px] font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest hover:text-blue-800 dark:hover:text-blue-300">Detailed</a>
        </div>
        <div class="h-28 flex items-end justify-between space-x-1.5">
           <!-- Simple CSS Bar Chart -->
           <% 
             const streamVolume = Math.min((active_streams / (total_cameras || 1)) * 100, 100);
             const mockHeights = [10, 20, 15, 30, Math.max(streamVolume - 20, 10), Math.max(streamVolume - 10, 15), streamVolume, 45, 35, 25, 15, 20];
             mockHeights.forEach(h => { 
           %>
             <div class="w-full bg-blue-100 dark:bg-gray-700 rounded-t hover:bg-blue-500 dark:hover:bg-blue-500 transition-colors" style="height: <%= h %>%"></div>
           <% }) %>
        </div>
      </div>
    </div>
  </div>
</main>
