<!-- Main Content -->
<main class="p-4 sm:ml-64 pt-20 sm:pt-4 min-h-screen bg-gray-50 dark:bg-gray-900">
  
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-4">
    <!-- Welcome Banner (Shrunk) -->
    <div class="lg:col-span-2">
      <div class="bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/10 rounded-xl p-4 border border-blue-200 dark:border-blue-800 h-full flex flex-col justify-center">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
          <div>
            <h2 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-1">
              Welcome back, <span class="gradient-text">Admin!</span>
            </h2>
            <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">
              Monitor your live streams and manage equipment.
            </p>
          </div>
          <div class="flex items-center space-x-3">
            <div class="text-right hidden md:block">
              <div class="flex items-center">
                <div class="w-2 h-2 rounded-full bg-green-500 mr-2 animate-pulse"></div>
                <p class="text-sm font-bold text-green-600 dark:text-green-400">
                  Systems Operational
                </p>
              </div>
            </div>
            <button class="btn-gradient text-white font-medium rounded-lg px-4 py-2 text-xs inline-flex items-center whitespace-nowrap">
              <i class="fas fa-play mr-2"></i> Quick Stream
            </button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Top Quick Actions Panel -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 flex flex-col justify-center">
      <div class="grid grid-cols-2 gap-2">
        <a href="/camera/add" class="flex flex-col items-center justify-center p-2 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors border border-blue-100 dark:border-blue-800/50">
          <i class="fas fa-video mb-1 text-lg"></i>
          <span class="text-xs font-semibold">Add Camera</span>
        </a>
        <a href="/dvr/add" class="flex flex-col items-center justify-center p-2 rounded-lg bg-purple-50 dark:bg-purple-900/20 text-purple-700 dark:text-purple-400 hover:bg-purple-100 dark:hover:bg-purple-900/40 transition-colors border border-purple-100 dark:border-purple-800/50">
          <i class="fas fa-server mb-1 text-lg"></i>
          <span class="text-xs font-semibold">Add DVR</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Stats Overview -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
    <!-- Total Locations Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 card-hover">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Locations</p>
        <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center">
          <i class="fas fa-building text-blue-600 dark:text-blue-400 text-sm"></i>
        </div>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= total_dvrs || 0 %></h3>
      <div class="flex items-center text-xs space-x-2">
        <span class="text-green-600 dark:text-green-400 font-medium bg-green-50 dark:bg-green-900/30 px-1.5 py-0.5 rounded"><i class="fas fa-arrow-up mr-1 invisible"></i><%= activeDvrs.length %> Online</span>
        <span class="text-red-500 dark:text-red-400"><%= total_dvrs - activeDvrs.length %> Offline</span>
      </div>
    </div>

    <!-- Total Cameras Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 card-hover">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Cameras</p>
        <div class="w-8 h-8 rounded-lg bg-purple-50 dark:bg-purple-900/30 flex items-center justify-center">
          <i class="fas fa-video text-purple-600 dark:text-purple-400 text-sm"></i>
        </div>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= total_cameras || 0 %></h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 truncate">Total connected devices</p>
    </div>

    <!-- Live Streams Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 card-hover">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Live Streams</p>
        <div class="w-8 h-8 rounded-lg bg-green-50 dark:bg-green-900/30 flex items-center justify-center">
           <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse absolute"></div>
        </div>
      </div>
      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= active_streams || 0 %></h3>
      <p class="text-xs text-green-600 dark:text-green-400 font-medium">Streaming active</p>
    </div>

  </div>

  <!-- Two Column Layout Area -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
    <!-- Live DVRs List -->
    <div class="xl:col-span-2">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden h-full flex flex-col">
        <!-- Header -->
        <div class="px-6 py-4 flex items-center justify-between border-b border-gray-100 dark:border-gray-700 bg-white dark:bg-gray-800">
          <h3 class="text-base font-bold text-gray-900 dark:text-white">Active DVR Streams</h3>
          <a href="/dvr" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-700 font-semibold transition-colors">View All</a>
        </div>

        <!-- DVRs List Table (Responsive) -->
        <div class="flex-1 flex flex-col">
          <!-- Table Header (Hidden on Mobile) -->
          <div class="hidden md:block px-6 py-3.5 border-b border-gray-100 dark:border-gray-700/50 bg-gray-50/30 dark:bg-gray-800/30">
            <div class="grid grid-cols-12 gap-4 text-xs font-semibold text-gray-500 dark:text-gray-400">
              <div class="col-span-4 text-gray-500 dark:text-gray-400">DVR Name</div>
              <div class="col-span-3 text-gray-500 dark:text-gray-400">Location</div>
              <div class="col-span-2 text-gray-500 dark:text-gray-400">Cameras</div>
              <div class="col-span-2 text-center text-gray-500 dark:text-gray-400">Status</div>
              <div class="col-span-1 text-right"></div>
            </div>
          </div>
          
          <div class="divide-y divide-gray-100 dark:divide-gray-700/50 flex-1">
            <% if (activeDvrs.length > 0) { %> 
              <% activeDvrs.slice(0, 5).forEach(dvr => { %>
                <!-- ✅ DVR ROW ROOT -->
                <div class="px-4 py-4 md:px-6 hover:bg-gray-50/50 dark:hover:bg-gray-800/50 transition-colors group">
                  <div class="flex flex-col md:grid md:grid-cols-12 gap-3 md:gap-4 md:items-center">
                    
                    <!-- DVR Name & Mobile Action -->
                    <div class="md:col-span-4 flex items-center justify-between space-x-3 w-full">
                      <div class="flex items-center space-x-3 w-full">
                        <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(dvr.dvr_name) %>&background=e0e7ff&color=4f46e5&rounded=true&bold=true&size=32" alt="Avatar" class="w-8 h-8 rounded-full shadow-sm shrink-0">
                        <span class="font-semibold text-gray-900 dark:text-white truncate flex-1"><%= dvr.dvr_name %></span>
                        
                        <!-- Mobile Action Icon -->
                        <div class="md:hidden shrink-0">
                          <a href="/public/dvr/<%= dvr.id %>" target="_blank" class="inline-flex items-center justify-center w-8 h-8 text-blue-600 bg-blue-50 rounded-full dark:text-blue-400 dark:bg-blue-900/30">
                            <i class="fas fa-eye text-sm"></i>
                          </a>
                        </div>
                      </div>
                    </div>

                    <!-- Location -->
                    <div class="md:col-span-3 flex items-center text-sm pt-2 border-t md:border-0 md:pt-0 border-gray-100 dark:border-gray-700 md:col-start-auto">
                      <i class="fas fa-map-marker-alt text-gray-400 mr-2 shrink-0 md:hidden"></i>
                      <span class="text-gray-600 dark:text-gray-300 truncate"><%= dvr.location_name || 'Unassigned' %></span>
                    </div>

                    <!-- Cameras -->
                    <div class="md:col-span-2 flex items-center text-sm border-t md:border-0 md:pt-0 pt-2 border-gray-100 dark:border-gray-700">
                      <i class="fas fa-video text-gray-400 mr-2 shrink-0 md:hidden"></i>
                      <span class="text-gray-900 dark:text-gray-200 font-medium"><%= dvr.activeCameraCount %></span>
                      <span class="text-gray-400 text-xs ml-1"> active</span>
                    </div>

                    <!-- Status -->
                    <div class="md:col-span-2 flex justify-end md:justify-center border-t md:border-0 md:pt-0 pt-2 mt-2 md:mt-0 border-gray-100 dark:border-gray-700">
                       <span class="inline-flex items-center justify-center px-4 py-1 text-[11px] font-semibold tracking-wide border rounded-full text-green-600 border-green-200 bg-green-50 dark:bg-green-900/10 dark:text-green-400 dark:border-green-800/30">
                          Online
                       </span>
                    </div>

                    <!-- Desktop Actions -->
                    <div class="hidden md:flex md:col-span-1 justify-end">
                      <a href="/public/dvr/<%= dvr.id %>" target="_blank" class="inline-flex items-center justify-center w-8 h-8 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-full transition-colors dark:hover:bg-gray-700 opacity-0 group-hover:opacity-100" title="Live View">
                        <i class="fas fa-eye text-sm"></i>
                      </a>
                    </div>
                    
                  </div>
                </div>
              <% }); %> 
            <% } else { %>
              <div class="px-6 py-12 flex flex-col items-center justify-center h-[200px]">
                <div class="flex flex-col items-center justify-center opacity-60">
                  <div class="w-12 h-12 mb-3 rounded-full bg-gray-50 dark:bg-gray-800 flex items-center justify-center border border-dashed border-gray-300 dark:border-gray-600">
                    <i class="fas fa-video-slash text-gray-400"></i>
                  </div>
                  <p class="text-sm font-medium text-gray-600 dark:text-gray-300">No active streams to display.</p>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column Metrics -->
    <div class="space-y-4">
      <!-- Recent Activity Section (Moved from Navbar) -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5 h-full">
        <h3 class="text-xs font-bold text-gray-900 dark:text-white uppercase tracking-wide mb-3">Recent Activity</h3>
        <div class="space-y-3">
          <% if (typeof recentActivities !== 'undefined' && recentActivities.length > 0) { %>
            <% recentActivities.slice(0, 10).forEach(activity => { 
                let colorClass = "bg-gray-500 border-gray-200";
                if (activity.source_type === "camera") colorClass = "bg-blue-500 border-blue-200";
                else if (activity.source_type === "dvr") colorClass = "bg-green-500 border-green-200";
                else if (activity.source_type === "system") colorClass = "bg-purple-500 border-purple-200";
                else if (activity.action === "deleted") colorClass = "bg-red-500 border-red-200";
            %>
              <div class="flex items-start text-xs group" title="<%= new Date(activity.created_at).toLocaleString() %>">
                <div class="w-1.5 h-1.5 rounded-full <%= colorClass %> mt-1.5 mr-3 flex-shrink-0 shadow-sm shadow-[<%= colorClass.split(' ')[0] %>/30]"></div>
                <div class="flex-1 min-w-0">
                   <p class="text-gray-700 dark:text-gray-300 font-medium truncate group-hover:text-blue-600 transition-colors"><%= activity.description %></p>
                   <p class="text-[10px] text-gray-400 mt-0.5"><%= new Date(activity.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></p>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="text-sm text-gray-500 dark:text-gray-400 italic py-4 text-center">No recent system activity</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>
