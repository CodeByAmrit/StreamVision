<main class="p-4 sm:ml-64 mt-16 min-h-screen bg-gray-50/50 dark:bg-gray-900/50">
  <!-- Quick Stats -->
  <div class="mb-4 grid grid-cols-1 md:grid-cols-3 gap-4">
    <div
      class="bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/10 rounded-xl p-4 border border-blue-200 dark:border-blue-800"
    >
      <div class="flex items-center">
        <div
          class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-100 to-blue-50 dark:from-blue-900/30 dark:to-blue-800/20 flex items-center justify-center mr-4"
        >
          <i class="fas fa-server text-blue-600 dark:text-blue-400"></i>
        </div>
        <div>
          <p class="text-sm text-gray-500 dark:text-gray-400">Total DVRs</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= typeof totalDvrs !== "undefined" ? totalDvrs : 0 %></p>
        </div>
      </div>
    </div>

    <div
      class="bg-gradient-to-r from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/10 rounded-xl p-4 border border-green-200 dark:border-green-800"
    >
      <div class="flex items-center">
        <div
          class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-100 to-green-50 dark:from-green-900/30 dark:to-green-800/20 flex items-center justify-center mr-4"
        >
          <i class="fas fa-wifi text-green-600 dark:text-green-400"></i>
        </div>
        <div>
          <p class="text-sm text-gray-500 dark:text-gray-400">Online DVRs</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= onlineCount || 0 %></p>
        </div>
      </div>
    </div>

    <div
      class="bg-gradient-to-r from-purple-50 to-purple-100 dark:from-purple-900/20 dark:to-purple-800/10 rounded-xl p-4 border border-purple-200 dark:border-purple-800"
    >
      <div class="flex items-center">
        <div
          class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-100 to-purple-50 dark:from-purple-900/30 dark:to-purple-800/20 flex items-center justify-center mr-4"
        >
          <i class="fas fa-camera text-purple-600 dark:text-purple-400"></i>
        </div>
        <div>
          <p class="text-sm text-gray-500 dark:text-gray-400">Total Cameras</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= totalCameras || 0 %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Search and Filters Card -->
  <div
    class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-blue-100 dark:border-gray-700 p-4 mb-4"
  >
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
      <!-- Search Form -->
      <form method="GET" action="/dvr" class="flex-1">
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="fas fa-search text-gray-400"></i>
          </div>
          <input
            type="text"
            id="search"
            name="search"
            value="<%= search || '' %>"
            class="w-full pl-10 pr-4 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-blue-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-gray-900 dark:text-white transition-all"
            placeholder="Search DVRs by name or location..."
          />
          <button
            type="submit"
            class="absolute inset-y-0 right-0 px-4 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
          >
            <i class="fas fa-arrow-right"></i>
          </button>
        </div>
      </form>

      <!-- Status Filter -->
      <div class="flex items-center space-x-3">
        <select
          id="status-filter"
          class="px-3 py-2 text-sm bg-gray-50 dark:bg-gray-700 border border-blue-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-gray-900 dark:text-white transition-all"
        >
          <% if (status === 'all') { %>
          <option value="all" selected>All Status</option>
          <% } else { %>
          <option value="all">All Status</option>
          <% } %> <% if (status === 'online') { %>
          <option value="online" selected>Online Only</option>
          <% } else { %>
          <option value="online">Online Only</option>
          <% } %> <% if (status === 'offline') { %>
          <option value="offline" selected>Offline Only</option>
          <% } else { %>
          <option value="offline">Offline Only</option>
          <% } %>
        </select>

        <button
          id="refresh-btn"
          class="p-2 w-[38px] h-[38px] flex items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 hover:bg-blue-200 dark:hover:bg-blue-800/50 transition-colors"
        >
          <i class="fas fa-sync-alt"></i>
        </button>

        <a
          href="/dvr/add"
          class="btn-gradient text-white font-medium rounded-lg px-4 py-2 text-sm inline-flex items-center whitespace-nowrap"
        >
          <i class="fas fa-plus mr-1.5"></i>
          Add DVR
        </a>
      </div>
    </div>
  </div>

  <!-- DVR List Card -->
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-x-auto">
    <table class="w-full text-left text-sm whitespace-nowrap">
      <thead class="text-xs text-gray-500 dark:text-gray-400 font-medium border-b border-gray-100 dark:border-gray-700/50 bg-gray-50/30 dark:bg-gray-800/30">
        <tr>
          <th scope="col" class="px-5 py-4 w-12 text-center rounded-tl-2xl">
             <i class="far fa-check-circle text-gray-300 dark:text-gray-600 text-base"></i>
          </th>
          <th scope="col" class="px-4 py-4 w-28">DVR ID <span class="text-gray-300 dark:text-gray-600 ml-1">⋮</span></th>
          <th scope="col" class="px-4 py-4">Name <span class="text-gray-300 dark:text-gray-600 ml-1">⋮</span></th>
          <th scope="col" class="px-4 py-4">Location <span class="text-gray-300 dark:text-gray-600 ml-1">⋮</span></th>
          <th scope="col" class="px-4 py-4">Cameras <span class="text-gray-300 dark:text-gray-600 ml-1">⋮</span></th>
          <th scope="col" class="px-4 py-4 text-center">Status <span class="text-gray-300 dark:text-gray-600 ml-1">⋮</span></th>
          <th scope="col" class="px-5 py-4 w-14 rounded-tr-2xl text-center"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-700/50">
        <% if (dvrsWithCameras && dvrsWithCameras.length > 0) { %>
        <% dvrsWithCameras.forEach((dvr, index) => { %>
          <%
            const isOnline = dvr.isOnline === true;
            const statusClass = isOnline
              ? "text-green-600 border-green-200 bg-white dark:bg-green-900/10 dark:text-green-400 dark:border-green-800/30"
              : "text-red-500 border-red-200 bg-white dark:bg-red-900/10 dark:text-red-400 dark:border-red-800/30";
            const statusText = isOnline ? "Online" : "Offline";
            const activeCameras = dvr.activeCameras || 0;
            const totalCameras = dvr.totalCameras || 0;
          %>
        <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-800/50 transition-colors group" data-dvr-id="<%= dvr.id %>">
          <td class="px-5 py-3.5 text-center">
             <i class="far fa-check-circle text-gray-300 dark:text-gray-600 group-hover:text-blue-500 transition-colors text-base cursor-pointer"></i>
          </td>
          <td class="px-4 py-3.5 text-gray-500 dark:text-gray-400 font-medium">
            <%= dvr.id %>
          </td>
          <td class="px-4 py-3.5">
            <div class="flex items-center gap-3">
              <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(dvr.dvr_name) %>&background=e0e7ff&color=4f46e5&rounded=true&bold=true&size=32" alt="Avatar" class="w-8 h-8 rounded-full shadow-sm">
              <span class="font-semibold text-gray-900 dark:text-white"><%= dvr.dvr_name %></span>
            </div>
          </td>
          <td class="px-4 py-3.5 text-gray-600 dark:text-gray-300">
            <%= dvr.location_name || 'Unassigned' %>
          </td>
          <td class="px-4 py-3.5">
            <div class="flex items-center gap-1.5">
              <span class="text-gray-900 dark:text-gray-200 font-medium"><%= activeCameras %></span>
              <span class="text-gray-400 dark:text-gray-500 text-xs">/ <%= totalCameras %></span>
            </div>
          </td>
          <td class="px-4 py-3.5 text-center">
             <span class="inline-flex items-center justify-center px-4 py-1 text-[11px] font-semibold tracking-wide border rounded-full <%= statusClass %>">
                <%= statusText %>
             </span>
          </td>
          <td class="px-5 py-3.5 text-center">
            <div class="relative inline-block text-left opacity-0 group-hover:opacity-100 transition-opacity hidden md:block">
              <div class="flex items-center justify-center gap-2">
                <a href="/public/dvr/<%= dvr.id %>" target="_blank" class="w-7 h-7 inline-flex items-center justify-center text-gray-400 hover:text-green-600 hover:bg-green-50 rounded-full transition-colors dark:hover:bg-gray-700" title="<%= isOnline ? 'Live' : 'View' %>">
                   <i class="fas fa-eye text-xs"></i>
                </a>
                <a href="/dvr/edit/<%= dvr.id %>" class="w-7 h-7 inline-flex items-center justify-center text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-full transition-colors dark:hover:bg-gray-700" title="Edit">
                   <i class="fas fa-pen text-xs"></i>
                </a>
                <button type="button" data-dvr-id="<%= dvr.id %>" data-dvr-name="<%= dvr.dvr_name %>" class="delete-dvr-btn w-7 h-7 inline-flex items-center justify-center text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-full transition-colors dark:hover:bg-gray-700" title="Delete">
                   <i class="fas fa-trash text-xs"></i>
                </button>
                <button type="button" class="w-7 h-7 inline-flex items-center justify-center text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-full transition-colors dark:hover:bg-gray-700 dark:hover:text-gray-300" title="More options">
                   <i class="fas fa-ellipsis-v text-xs"></i>
                </button>
              </div>
            </div>
            <!-- Mobile fallback for actions -->
            <div class="flex md:hidden items-center justify-center gap-3">
                 <button type="button" class="text-gray-400 hover:text-gray-600"><i class="fas fa-ellipsis-v"></i></button>
            </div>
          </td>
        </tr>
        <% }); %>
        <% } else { %>
        <tr>
          <td colspan="7" class="px-6 py-16 text-center">
             <div class="flex flex-col items-center justify-center opacity-60">
                <div class="w-16 h-16 mb-4 rounded-full bg-gray-50 dark:bg-gray-800 flex items-center justify-center border border-gray-200 dark:border-gray-700 shadow-sm">
                  <i class="fas fa-server text-2xl text-gray-400"></i>
                </div>
                <p class="text-base font-medium text-gray-600 dark:text-gray-300">No DVRs Found</p>
                <p class="text-sm text-gray-400 mt-1">Add a new DVR to get started</p>
             </div>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>


    <!-- Pagination Footer -->
    <% if (dvrsWithCameras && dvrsWithCameras.length > 0) { %>
    <div
      class="px-4 py-3 border-t border-blue-50 dark:border-gray-700 bg-blue-50/50 dark:bg-blue-900/20"
    >
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <!-- Page Info -->
        <div class="text-sm text-gray-600 dark:text-gray-400">
          Showing
          <span class="font-semibold text-gray-900 dark:text-white">
            <% const start = (currentPage - 1) * limit + 1; const end = Math.min(currentPage *
            limit, typeof filteredTotal !== 'undefined' ? filteredTotal : totalDvrs); %> <%= start
            %>-<%= end %>
          </span>
          of
          <span class="font-semibold text-gray-900 dark:text-white">
            <%= typeof filteredTotal !== 'undefined' ? filteredTotal : totalDvrs %>
          </span>
          DVRs <% if (status && status !== 'all') { %>
          <span class="text-blue-600 dark:text-blue-400 ml-2">(Filtered: <%= status %>)</span>
          <% } %>
        </div>

        <!-- Pagination Controls -->
        <div class="flex items-center space-x-2">
          <% if (currentPage > 1) { %>
          <a
            href="?page=<%= currentPage - 1 %>&search=<%= search %><% if (status && status !== 'all') { %>&status=<%= status %><% } %>"
            class="inline-flex items-center px-2 py-1.5 text-sm rounded bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
          >
            <i class="fas fa-chevron-left mr-1.5"></i>
            Prev
          </a>
          <% } %>

          <!-- Page Numbers -->
          <div class="hidden md:flex items-center space-x-1">
            <% let startPage = Math.max(1, currentPage - 2); let endPage = Math.min(totalPages,
            currentPage + 2); if (startPage > 1) { %>
            <a
              href="?page=1&search=<%= search %><% if (status && status !== 'all') { %>&status=<%= status %><% } %>"
              class="inline-flex items-center justify-center w-8 h-8 text-sm rounded bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
            >
              1
            </a>
            <% if (startPage > 2) { %>
            <span class="px-1 text-gray-500">...</span>
            <% } %> <% } %> <% for (let i = startPage; i <= endPage; i++) { %>
            <a
              href="?page=<%= i %>&search=<%= search %><% if (status && status !== 'all') { %>&status=<%= status %><% } %>"
              class="inline-flex items-center justify-center w-8 h-8 text-sm rounded <%= currentPage === i ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' %> transition-colors"
            >
              <%= i %>
            </a>
            <% } %> <% if (endPage < totalPages) { %> <% if (endPage < totalPages - 1) { %>
            <span class="px-1 text-gray-500">...</span>
            <% } %>
            <a
              href="?page=<%= totalPages %>&search=<%= search %><% if (status && status !== 'all') { %>&status=<%= status %><% } %>"
              class="inline-flex items-center justify-center w-8 h-8 text-sm rounded bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
            >
              <%= totalPages %>
            </a>
            <% } %>
          </div>

          <% if (currentPage < totalPages) { %>
          <a
            href="?page=<%= currentPage + 1 %>&search=<%= search %><% if (status && status !== 'all') { %>&status=<%= status %><% } %>"
            class="inline-flex items-center px-2 py-1.5 text-sm rounded bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
          >
            Next
            <i class="fas fa-chevron-right ml-1.5"></i>
          </a>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4">
      <div class="fixed inset-0 bg-black opacity-30"></div>
      <div class="relative bg-white dark:bg-gray-800 rounded-xl shadow-xl w-full max-w-md mx-auto">
        <div class="p-5">
          <div
            class="flex items-center justify-center w-14 h-14 rounded-full bg-red-100 dark:bg-red-900/30 mx-auto mb-3"
          >
            <i class="fas fa-exclamation-triangle text-red-600 dark:text-red-400 text-xl"></i>
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white text-center mb-1.5">
            Delete DVR
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 text-center mb-5">
            Are you sure you want to delete
            <span id="dvr-name" class="font-semibold text-gray-900 dark:text-white"></span>? This action cannot be undone.
          </p>
          <div class="flex justify-center space-x-3">
            <button
              id="cancel-delete"
              class="px-4 py-2 text-sm text-gray-700 dark:text-gray-300 font-medium rounded-lg border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
            >
              Cancel
            </button>
            <button
              id="confirm-delete"
              class="px-4 py-2 text-sm bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition-colors"
            >
              Delete DVR
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
