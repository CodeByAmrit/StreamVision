<main class="p-4 sm:p-6 sm:ml-64 pt-20 sm:pt-6 min-h-screen bg-gray-50 dark:bg-gray-900">
  
  <!-- Header & Toolbar -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-5">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white tracking-tight">DVR Management</h1>
    </div>
    
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2.5 w-full md:w-auto">
      <!-- Search -->
      <form method="GET" action="/dvr" class="relative w-full sm:w-64">
        <i class="fas fa-search absolute left-3 top-3 text-gray-400 text-xs"></i>
        <input type="text" name="search" value="<%= search || '' %>" placeholder="Search DVRs..." class="w-full pl-8 pr-3 py-3 text-xs bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 dark:text-white transition-shadow shadow-sm">
      </form>
      <!-- Filters & Actions -->
      <div class="flex gap-2.5">
        <select id="status-filter" class="w-full sm:w-auto py-2 px-3 text-xs bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg dark:text-white shadow-sm focus:ring-2 focus:ring-blue-500/50 cursor-pointer">
          <option value="all" <%= status === 'all' ? 'selected' : '' %>>All Status</option>
          <option value="online" <%= status === 'online' ? 'selected' : '' %>>Online</option>
          <option value="offline" <%= status === 'offline' ? 'selected' : '' %>>Offline</option>
        </select>
        
        <button id="refresh-btn" class="px-3 py-2 text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 shadow-sm transition-colors" title="Refresh Data">
          <i class="fas fa-sync-alt text-xs"></i>
        </button>
        
        <a href="/dvr/add" class="px-4 py-2 text-xs font-semibold bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center justify-center whitespace-nowrap shadow-sm transition-colors">
          <i class="fas fa-plus mr-1.5 opacity-80"></i> Add DVR
        </a>
      </div>
    </div>
  </div>

  <!-- Compact System Overview -->
  <div class="grid grid-cols-3 gap-4 mb-5">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400 flex items-center justify-center">
        <i class="fas fa-server"></i>
      </div>
      <div>
        <p class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Total DVRs</p>
        <p class="text-sm font-bold text-gray-900 dark:text-white leading-tight"><%= typeof totalDvrs !== 'undefined' ? totalDvrs : 0 %></p>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-green-50 dark:bg-green-900/40 text-green-600 dark:text-green-400 flex items-center justify-center">
        <i class="fas fa-check-circle"></i>
      </div>
      <div>
        <p class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Online Systems</p>
        <p class="text-sm font-bold text-gray-900 dark:text-white leading-tight"><%= typeof onlineCount !== 'undefined' ? onlineCount : 0 %></p>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-3 flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-purple-50 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400 flex items-center justify-center">
        <i class="fas fa-video"></i>
      </div>
      <div>
        <p class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Total Cameras</p>
        <p class="text-sm font-bold text-gray-900 dark:text-white leading-tight"><%= typeof totalCameras !== 'undefined' ? totalCameras : 0 %></p>
      </div>
    </div>
  </div>

  <!-- DVR List Container & Sidebar Grid -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    
    <!-- Left Column: DVR List Container (2/3 width on xl) -->
    <div class="xl:col-span-2 flex flex-col h-full">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden flex-1">
    <!-- Table Header (Desktop) -->
    <div class="hidden md:grid grid-cols-12 gap-4 px-5 py-2.5 bg-gray-50/80 dark:bg-gray-800/80 border-b border-gray-200 dark:border-gray-700 text-[11px] font-bold text-gray-500 dark:text-gray-400 tracking-wider uppercase">
      <div class="col-span-4">System Details</div>
      <div class="col-span-3">Location</div>
      <div class="col-span-2">Cameras</div>
      <div class="col-span-2">Health</div>
      <div class="col-span-1 text-right">Actions</div>
    </div>

    <!-- DVR Rows -->
    <div class="divide-y divide-gray-100 dark:divide-gray-700/60">
      <% if (dvrsWithCameras && dvrsWithCameras.length > 0) { %>
        <% dvrsWithCameras.forEach((dvr) => { %>
          <%
            const isOnline = dvr.isOnline === true;
            const activeCameras = dvr.activeCameras || 0;
            const totalCameras = dvr.totalCameras || 0;
            const searchParams = (search ? '&search=' + search : '') + (status !== 'all' ? '&status=' + status : '');
          %>
          <div class="px-4 py-3 md:px-5 hover:bg-gray-50/60 dark:hover:bg-gray-700/30 transition-colors group" data-dvr-id="<%= dvr.id %>">
            <div class="flex flex-col md:grid md:grid-cols-12 gap-2 md:gap-4 md:items-center">
              
              <!-- 1: Name & ID -->
              <div class="md:col-span-4 flex items-center justify-between">
                <div class="flex items-center gap-3 w-full">
                  <div class="w-8 h-8 rounded shrink-0 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center border border-blue-100 dark:border-blue-800/40">
                    <i class="fas fa-server text-sm"></i>
                  </div>
                  <div class="min-w-0 flex-1">
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white truncate"><%= dvr.dvr_name %></h4>
                    <p class="text-[11px] text-gray-500 dark:text-gray-400 font-mono mt-0.5">ID: <%= dvr.id %></p>
                  </div>
                </div>
                <!-- Mobile Status Indicator -->
                <div class="md:hidden shrink-0 flex items-center">
                  <div class="w-2 h-2 rounded-full <%= isOnline ? 'bg-green-500' : 'bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.6)]' %>"></div>
                </div>
              </div>

              <!-- 2: Location -->
              <div class="md:col-span-3 flex items-center text-xs text-gray-600 dark:text-gray-300">
                <i class="fas fa-map-marker-alt text-gray-400 mr-2 shrink-0 w-3 text-center"></i>
                <span class="truncate"><%= dvr.location_name || 'Unassigned' %></span>
              </div>

              <!-- 3: Cameras -->
              <div class="md:col-span-2 flex items-center text-xs text-gray-600 dark:text-gray-300">
                <i class="fas fa-video text-gray-400 mr-2 shrink-0 w-3 text-center"></i>
                <span class="font-semibold text-gray-800 dark:text-gray-200"><%= activeCameras %></span>
                <span class="text-gray-400 dark:text-gray-500 ml-1">/ <%= totalCameras %> Online</span>
              </div>

              <!-- 4: Status Badge (Desktop) -->
              <div class="hidden md:flex md:col-span-2 items-center">
                <div class="flex items-center px-2 py-1 rounded-md text-[11px] font-bold tracking-wide uppercase <%= isOnline ? 'bg-green-50 text-green-700 border border-green-200/60 dark:bg-green-500/10 dark:text-green-400 dark:border-green-500/20' : 'bg-red-50 text-red-700 border border-red-200/60 dark:bg-red-500/10 dark:text-red-400 dark:border-red-500/20' %>">
                  <div class="w-1.5 h-1.5 rounded-full mr-1.5 <%= isOnline ? 'bg-green-500' : 'bg-red-500' %>"></div>
                  <%= isOnline ? 'Online' : 'Offline' %>
                </div>
              </div>

              <!-- 5: Actions -->
              <div class="md:col-span-1 flex items-center justify-end gap-1 mt-2 pt-2 md:mt-0 md:pt-0 border-t border-gray-100 dark:border-gray-700/50 md:border-0">
                <a href="/public/dvr/<%= dvr.id %>" target="_blank" class="w-8 h-8 rounded-lg inline-flex items-center justify-center text-gray-400 hover:text-green-600 hover:bg-green-50 dark:hover:text-green-400 dark:hover:bg-gray-700 transition-colors" title="Live View">
                  <i class="fas fa-eye text-[13px]"></i>
                </a>
                <a href="/dvr/edit/<%= dvr.id %>" class="w-8 h-8 rounded-lg inline-flex items-center justify-center text-gray-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:text-blue-400 dark:hover:bg-gray-700 transition-colors" title="Edit Configuration">
                  <i class="fas fa-edit text-[13px]"></i>
                </a>
                <button type="button" data-dvr-id="<%= dvr.id %>" data-dvr-name="<%= dvr.dvr_name %>" class="delete-dvr-btn w-8 h-8 rounded-lg inline-flex items-center justify-center text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:text-red-400 dark:hover:bg-gray-700 transition-colors" title="Delete DVR">
                  <i class="fas fa-trash-alt text-[13px]"></i>
                </button>
              </div>

            </div>
          </div>
        <% }); %>
      <% } else { %>
        <!-- Empty State -->
        <div class="px-6 py-12 flex flex-col items-center justify-center text-center opacity-70">
          <i class="fas fa-hdd text-3xl text-gray-300 dark:text-gray-600 mb-3"></i>
          <p class="text-sm font-semibold text-gray-600 dark:text-gray-300">No DVRs found.</p>
          <p class="text-xs text-gray-400 mt-1 max-w-sm">There are no units matching your current filters. Adjust your search or add a new DVR to the system.</p>
        </div>
      <% } %>
    </div>

    <!-- Compact Pagination -->
    <% if (dvrsWithCameras && dvrsWithCameras.length > 0) { %>
      <div class="px-5 py-3 bg-gray-50/50 dark:bg-gray-800/30 border-t border-gray-200 dark:border-gray-700 flex flex-col sm:flex-row items-center justify-between gap-3">
        <div class="text-[11px] text-gray-500 dark:text-gray-400 font-medium">
          <% const start = (currentPage - 1) * limit + 1; const totalFiltered = typeof filteredTotal !== 'undefined' ? filteredTotal : totalDvrs; const end = Math.min(currentPage * limit, totalFiltered); %>
          Showing <span class="text-gray-900 dark:text-gray-200"><%= start %>-<%= end %></span> of <span class="text-gray-900 dark:text-gray-200"><%= totalFiltered %></span> DVRs
        </div>
        
        <div class="flex items-center gap-1.5">
          <% 
             const searchParam = search ? '&search=' + search : '';
             const statusParam = (status && status !== 'all') ? '&status=' + status : '';
             const queryStr = searchParam + statusParam;
          %>
          
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %><%= queryStr %>" class="inline-flex items-center px-2 py-1 text-[11px] font-medium rounded border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
              <i class="fas fa-chevron-left mr-1"></i> Prev
            </a>
          <% } %>
          
          <!-- Smart Page Numbers -->
          <div class="hidden sm:flex items-center gap-1">
            <% 
               let startPage = Math.max(1, currentPage - 1); 
               let endPage = Math.min(totalPages, currentPage + 1); 
               if (startPage > 1) { 
            %>
               <a href="?page=1<%= queryStr %>" class="w-6 h-6 flex items-center justify-center text-[11px] font-medium rounded border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">1</a>
               <% if (startPage > 2) { %><span class="text-gray-400 text-[10px] px-0.5">...</span><% } %>
            <% } %>
            
            <% for(let i = startPage; i <= endPage; i++) { %>
              <a href="?page=<%= i %><%= queryStr %>" class="w-6 h-6 flex items-center justify-center text-[11px] font-medium rounded border transition-colors <%= currentPage === i ? 'border-blue-500 bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:border-blue-500/50 dark:text-blue-400' : 'border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600' %>">
                <%= i %>
              </a>
            <% } %>
            
            <% if (endPage < totalPages) { %>
               <% if (endPage < totalPages - 1) { %><span class="text-gray-400 text-[10px] px-0.5">...</span><% } %>
               <a href="?page=<%= totalPages %><%= queryStr %>" class="w-6 h-6 flex items-center justify-center text-[11px] font-medium rounded border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors"><%= totalPages %></a>
            <% } %>
          </div>

          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %><%= queryStr %>" class="inline-flex items-center px-2 py-1 text-[11px] font-medium rounded border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
              Next <i class="fas fa-chevron-right ml-1"></i>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>
      </div>
    </div>
    
    <!-- Right Column: DVR Detail Sidebar (1/3 width on xl) -->
    <div class="xl:col-span-1 h-full">
      <div id="dvr-detail-panel" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 h-full max-h-[calc(100vh-8rem)] flex flex-col overflow-hidden sticky top-24">
        
        <!-- Default Empty State -->
        <div id="dvr-detail-empty" class="flex-1 flex flex-col items-center justify-center p-8 text-center opacity-70">
          <i class="fas fa-hand-pointer text-4xl text-gray-300 dark:text-gray-600 mb-4"></i>
          <h3 class="text-sm font-bold text-gray-900 dark:text-white">Select a DVR</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">Click on any DVR row in the list to view its real-time camera status and diagnostic information.</p>
        </div>

        <!-- Loading State -->
        <div id="dvr-detail-loading" class="hidden flex-1 flex flex-col items-center justify-center p-8 text-center">
          <i class="fas fa-spinner fa-spin text-3xl text-blue-600 dark:text-blue-500 mb-4"></i>
          <p class="text-xs font-semibold text-gray-600 dark:text-gray-300">Probing RTSP Streams...</p>
          <p class="text-[10px] text-gray-400 mt-1">Checking real-time camera status. This may take a moment.</p>
        </div>

        <!-- Content State -->
        <div id="dvr-detail-content" class="hidden flex-1 flex flex-col overflow-hidden">
          <!-- Header -->
          <div class="p-5 border-b border-gray-100 dark:border-gray-700/60 bg-gray-50/50 dark:bg-gray-800/50">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 id="detail-dvr-name" class="text-base font-bold text-gray-900 dark:text-white truncate">DVR Name</h3>
                <p id="detail-dvr-location" class="text-xs text-gray-500 dark:text-gray-400 mt-1 truncate"><i class="fas fa-map-marker-alt mr-1"></i> Location</p>
              </div>
              <div id="detail-dvr-status" class="shrink-0 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border">
                Status
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-3 mt-4">
               <div class="bg-white dark:bg-gray-800 p-2.5 rounded border border-gray-200 dark:border-gray-700">
                 <p class="text-[10px] text-gray-400 uppercase font-bold tracking-wider mb-0.5">Active Streams</p>
                 <p id="detail-active-streams" class="text-sm font-bold text-gray-900 dark:text-white">0 / 0</p>
               </div>
               <div class="bg-white dark:bg-gray-800 p-2.5 rounded border border-gray-200 dark:border-gray-700">
                 <p class="text-[10px] text-gray-400 uppercase font-bold tracking-wider mb-0.5">Last Checked</p>
                 <p id="detail-last-checked" class="text-sm font-bold text-gray-900 dark:text-white text-xs truncate">Just now</p>
               </div>
            </div>
          </div>
          
          <!-- Camera List -->
          <div class="flex-1 overflow-y-auto p-4 space-y-3">
            <h4 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1 px-1">Connected Cameras</h4>
            <div id="detail-camera-list" class="space-y-2.5">
              <!-- Cameras injected via JS -->
            </div>
          </div>
          
          <!-- Actions -->
          <div class="p-4 border-t border-gray-100 dark:border-gray-700/60 bg-white dark:bg-gray-800">
            <a id="detail-btn-view" href="#" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 text-xs font-bold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm">
              <i class="fas fa-tv"></i> Open Stream Viewer
            </a>
          </div>
        </div>
        
      </div>
    </div>
  </div>
  <!-- Delete Modal Placeholder -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4">
      <div class="fixed inset-0 bg-gray-900/60 dark:bg-black/60 backdrop-blur-sm transition-opacity"></div>
      <div class="relative bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-sm mx-auto p-5 transform transition-all -translate-y-4">
        <div class="flex justify-center mb-3">
          <div class="w-12 h-12 rounded-full border-4 border-red-50 dark:border-red-900/20 bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400 flex items-center justify-center text-xl">
            <i class="fas fa-exclamation-circle"></i>
          </div>
        </div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white text-center mb-1.5">Delete Architecture</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 text-center mb-5 px-2">
          Permanently remove DVR <strong id="dvr-name" class="text-gray-800 dark:text-gray-200"></strong> and all associated streams? This cannot be undone.
        </p>
        <div class="flex gap-2.5">
          <button id="cancel-delete" class="flex-1 px-4 py-2 text-sm font-semibold text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">Cancel</button>
          <button id="confirm-delete" class="flex-1 px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 shadow-sm shadow-red-600/20 border border-transparent rounded-lg transition-colors">Delete Details</button>
        </div>
      </div>
    </div>
  </div>
</main>