<section class="p-4 sm:p-6 sm:ml-64 pt-20 sm:pt-6 min-h-screen bg-gray-50 dark:bg-gray-900">
  
  <!-- Breadcrumbs -->
  <nav class="flex mb-4" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 sm:space-x-2 text-xs font-medium">
      <li class="inline-flex items-center">
        <a href="/dashboard" class="inline-flex items-center text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white transition-colors">
          <i class="fas fa-home mr-1.5 opacity-80"></i> Dashboard
        </a>
      </li>
      <li>
        <div class="flex items-center">
          <i class="fas fa-chevron-right text-gray-400 text-[9px] mx-1"></i>
          <a href="/dvr" class="ml-1 text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white transition-colors">DVR Servers</a>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <i class="fas fa-chevron-right text-gray-400 text-[9px] mx-1"></i>
          <span class="ml-1 text-gray-800 dark:text-gray-200"><%= dvr.dvr_name %> Configuration</span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- DVR Details Summary Card -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5 mb-6">
     <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div class="flex items-center gap-4 w-full">
           <div class="w-12 h-12 rounded-lg bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center border border-blue-100 dark:border-blue-800/40 shrink-0">
             <i class="fas fa-server text-xl shadow-sm"></i>
           </div>
           <div class="flex-1 min-w-0">
             <h1 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight truncate"><%= dvr.dvr_name %></h1>
             <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400 mt-1">
               <span class="flex items-center truncate max-w-[150px] sm:max-w-none"><i class="fas fa-map-marker-alt mr-1.5 opacity-80"></i> <%= dvr.location_name || 'Unassigned Location' %></span>
               <span class="flex items-center shrink-0 border-l border-gray-300 dark:border-gray-600 pl-3"><i class="fas fa-fingerprint mr-1.5 opacity-80"></i> ID: <%= dvr.id %></span>
             </div>
           </div>
        </div>
        <div class="flex gap-2 w-full sm:w-auto shrink-0 mt-2 sm:mt-0">
           <a href="/dvr/edit/<%= dvr.id %>" class="flex-1 sm:flex-none justify-center px-4 py-2 text-xs font-bold tracking-wide text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors shadow-sm whitespace-nowrap">
             <i class="fas fa-cog mr-1.5 opacity-80"></i> DVR Settings
           </a>
           <button id="add-camera-top-btn" class="flex-1 sm:flex-none justify-center px-4 py-2 text-xs font-bold tracking-wide text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm whitespace-nowrap">
             <i class="fas fa-video mr-1.5 opacity-80"></i> Add Camera
           </button>
        </div>
     </div>
  </div>

  <!-- Camera Grid -->
  <% if (dvr.cameras && dvr.cameras.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-5">
      <% dvr.cameras.forEach((camera, index) => { %>
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm overflow-hidden flex flex-col group transition-all hover:shadow-md hover:border-blue-300 dark:hover:border-blue-500/50">
        
        <!-- Camera Stream Header -->
        <div class="px-3.5 py-2.5 border-b border-gray-100 dark:border-gray-700/60 flex justify-between items-center bg-gray-50/50 dark:bg-gray-800/50">
           <div class="flex items-center gap-2.5 truncate pr-2">
              <div class="w-2.5 h-2.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)] shrink-0 border border-green-200 dark:border-green-800"></div>
              <span class="text-xs font-bold text-gray-800 dark:text-gray-200 truncate tracking-wide"><%= camera.camera_name %></span>
           </div>
           
           <!-- Hover Actions -->
           <div class="flex items-center gap-1 opacity-100 sm:opacity-0 group-hover:opacity-100 transition-opacity">
              <button data-camera-id="<%= camera.id %>" data-camera-name="<%= camera.camera_name.replace(/"/g, '&quot;') %>" data-camera-url="<%= camera.rtsp_url.replace(/"/g, '&quot;') %>" class="edit-camera-btn w-7 h-7 rounded text-gray-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-gray-700 hover:shadow-sm transition-all flex items-center justify-center" title="Edit Camera">
                 <i class="fas fa-edit text-xs"></i>
              </button>
              <button data-camera-id="<%= camera.id %>" data-camera-name="<%= camera.camera_name.replace(/"/g, '&quot;') %>" class="delete-camera-btn w-7 h-7 rounded text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-gray-700 hover:shadow-sm transition-all flex items-center justify-center" title="Delete Camera">
                 <i class="fas fa-trash-alt text-xs"></i>
              </button>
           </div>
        </div>

        <!-- Video Player Container -->
        <div class="relative bg-black aspect-video flex-shrink-0 group-hover:brightness-105 transition-all">
          <video
            id="video<%= index + 1 %>"
            class="w-full h-full object-cover"
            controls
            muted
            autoplay
            playsinline
            preload="none"
          ></video>
          
          <!-- Stream Overlay Badges -->
          <div class="absolute top-2.5 left-2.5 flex gap-1.5 z-10">
             <span class="px-2 py-0.5 rounded text-[9px] font-bold text-white bg-black/60 backdrop-blur-md border border-white/10 uppercase tracking-widest flex items-center shadow-sm">
                <i class="fas fa-circle text-[5px] text-red-500 mr-1.5 animate-pulse"></i>Live
             </span>
             <span class="px-1.5 py-0.5 rounded text-[9px] font-bold text-white bg-black/60 backdrop-blur-md border border-white/10 uppercase tracking-widest shadow-sm">HQ</span>
          </div>
        </div>
        
        <!-- RTSP Info Footer -->
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800/50 flex items-center gap-3 w-full border-t border-gray-100 dark:border-gray-700/50 overflow-hidden">
           <div class="w-5 h-5 rounded-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 flex items-center justify-center shrink-0 shadow-sm">
             <i class="fas fa-link text-gray-400 text-[9px]"></i>
           </div>
           <span class="flex-1 min-w-0 text-[11px] text-gray-600 dark:text-gray-400 font-mono truncate tracking-tight" title="<%= camera.rtsp_url %>"><%= camera.rtsp_url %></span>
        </div>

      </div>
      <% }); %>
    </div>
  <% } else { %>
    <!-- Empty State -->
    <div class="px-6 py-20 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 border-dashed flex flex-col items-center justify-center text-center opacity-80 shadow-sm mt-4">
       <div class="w-16 h-16 rounded-full bg-blue-50 dark:bg-gray-700/50 flex items-center justify-center text-blue-400 dark:text-gray-400 mb-4 border border-blue-100 dark:border-gray-600">
         <i class="fas fa-video-slash text-2xl"></i>
       </div>
       <h3 class="text-sm font-bold text-gray-900 dark:text-white mb-1.5 tracking-wide">No Cameras Configured</h3>
       <p class="text-xs text-gray-500 dark:text-gray-400 max-w-sm mb-6 leading-relaxed">This DVR server currently has no RTSP cameras assigned to it. Add a camera to begin streaming and monitoring.</p>
       <button id="add-camera-empty-btn" class="px-5 py-2.5 text-xs font-bold tracking-wide text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-sm transition-colors uppercase">
         <i class="fas fa-plus mr-1.5 opacity-80"></i> Add First Camera
       </button>
    </div>
  <% } %>
</section>

<!-- Unified Camera Modal -->
<div id="camera-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6 overflow-hidden">
  <div id="modal-backdrop" class="absolute inset-0 bg-gray-900/60 dark:bg-black/60 backdrop-blur-sm transition-opacity"></div>
  <div class="relative z-10 bg-white dark:bg-gray-800 rounded-xl shadow-2xl text-left overflow-hidden transform transition-all w-full max-w-md border border-gray-200 dark:border-gray-700">
      
      <!-- Modal Header -->
      <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center bg-gray-50/50 dark:bg-gray-800/50">
        <h3 id="modal-title" class="text-sm font-bold text-gray-900 dark:text-white tracking-wide">Add New Camera</h3>
        <button type="button" class="close-modal-btn text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 bg-white dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 w-7 h-7 rounded-lg flex items-center justify-center transition-colors">
          <i class="fas fa-times text-xs"></i>
        </button>
      </div>
      
      <!-- Modal Form -->
      <form id="camera-form" method="POST" action="/camera/add">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="dvr_id" value="<%= dvr.id %>">
        <input type="hidden" id="edit-camera-id" name="id" value="">
        
        <div class="px-5 py-5 space-y-4.5">
          <!-- Camera Name -->
          <div class="space-y-1.5">
            <label for="camera_name" class="block text-xs font-bold tracking-wide text-gray-700 dark:text-gray-300 uppercase">Camera Name</label>
            <input type="text" id="camera_name" name="camera_name" required placeholder="e.g. Front Gate PTZ" class="w-full px-3.5 py-2.5 text-sm bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 dark:text-white shadow-sm transition-all placeholder-gray-400 font-medium">
          </div>
          
          <!-- RTSP URL -->
          <div class="space-y-1.5">
            <label for="rtsp_url" class="block text-xs font-bold tracking-wide text-gray-700 dark:text-gray-300 uppercase">RTSP Stream URL</label>
            <input type="text" id="rtsp_url" name="rtsp_url" required placeholder="rtsp://admin:pass@192.168.1.50:554/cam/..." class="w-full px-3.5 py-2.5 text-sm bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 dark:text-white shadow-sm transition-all font-mono placeholder-gray-400">
          </div>
        </div>
        
        <!-- Footer -->
        <div class="px-5 py-4 bg-gray-50 dark:bg-gray-800/80 border-t border-gray-100 dark:border-gray-700 flex justify-end gap-2.5">
          <button type="button" class="close-modal-btn px-5 py-2.5 text-xs font-bold tracking-wide text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors shadow-sm">Cancel</button>
          <button type="submit" id="modal-submit-btn" class="px-5 py-2.5 text-xs font-bold tracking-wide text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-sm transition-colors">Save Camera</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Add HLS.js -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest" nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>"></script>

<script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
  // Modal Dom Elements
  const modal = document.getElementById('camera-modal');
  const form = document.getElementById('camera-form');
  const title = document.getElementById('modal-title');
  const submitBtn = document.getElementById('modal-submit-btn');
  const idInput = document.getElementById('edit-camera-id');
  const nameInput = document.getElementById('camera_name');
  const urlInput = document.getElementById('rtsp_url');

  // Modal Logic Variables
  function openCameraModal(mode, id = '', name = '', url = '') {
    if (mode === 'edit') {
      title.innerText = 'Edit Camera Configuration';
      submitBtn.innerText = 'Save Changes';
      form.action = '/camera/edit/' + id;
      idInput.value = id;
      nameInput.value = name;
      urlInput.value = url;
    } else {
      title.innerText = 'Add New Camera';
      submitBtn.innerText = 'Add Camera';
      form.action = '/camera/add';
      idInput.value = '';
      nameInput.value = '';
      urlInput.value = '';
    }
    modal.classList.remove('hidden');
    setTimeout(() => nameInput.focus(), 50);
  }

  function closeCameraModal() {
    modal.classList.add('hidden');
  }
  
  // CSP Compliant Event Listeners
  document.addEventListener('DOMContentLoaded', () => {
    const addTopBtn = document.getElementById('add-camera-top-btn');
    if (addTopBtn) addTopBtn.addEventListener('click', () => openCameraModal('add'));
    
    const addEmptyBtn = document.getElementById('add-camera-empty-btn');
    if (addEmptyBtn) addEmptyBtn.addEventListener('click', () => openCameraModal('add'));
    
    document.querySelectorAll('.edit-camera-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        openCameraModal('edit', btn.getAttribute('data-camera-id'), btn.getAttribute('data-camera-name'), btn.getAttribute('data-camera-url'));
      });
    });
    
    document.querySelectorAll('.delete-camera-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const name = btn.getAttribute('data-camera-name');
        if (confirm(`Are you sure you want to permanently delete '${name}'?`)) {
          window.location.href = '/camera/delete/' + btn.getAttribute('data-camera-id');
        }
      });
    });
    
    document.querySelectorAll('.close-modal-btn').forEach(btn => btn.addEventListener('click', closeCameraModal));
    const backdrop = document.getElementById('modal-backdrop');
    if (backdrop) backdrop.addEventListener('click', closeCameraModal);
  });

  // Stream Logic
  const cameras = <%- JSON.stringify(dvr.cameras || []) %>;
  const dvrId = <%= dvr.id %>;

  async function tryLoadStream(camera, index, retries = 30, delay = 500) {
    const video = document.getElementById(`video${index + 1}`);
    if (!video) return;

    try {
      const res = await fetch(`/api/public/camera/${camera.id}/hls`);
      if (!res.ok) throw new Error("API error");
      const data = await res.json();
      if (!data.hlsUrl) throw new Error("No HLS URL");
      
      const source = data.hlsUrl;

      if (Hls.isSupported()) {
        const hls = new Hls({ lowLatencyMode: true });
        hls.loadSource(source);
        hls.attachMedia(video);
        hls.on(Hls.Events.MANIFEST_PARSED, () => {
          video.play().catch(() => {});
        });
        hls.on(Hls.Events.ERROR, function (event, data) {
          if (data.fatal) {
            hls.destroy();
            if (retries > 0) {
              setTimeout(() => tryLoadStream(camera, index, retries - 1, delay), delay);
            }
          }
        });
      } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = source;
        video.addEventListener('loadedmetadata', () => {
          video.play().catch(() => {});
        });
      }
    } catch (err) {
      if (retries > 0) {
        setTimeout(() => tryLoadStream(camera, index, retries - 1, delay), delay);
      }
    }
  }

  function loadAllStreams() {
    cameras.forEach((camera, index) => {
      tryLoadStream(camera, index);
    });
  }

  setTimeout(() => {
    loadAllStreams();
  }, 1000);

  setInterval(() => {
    loadAllStreams();
  }, 1000 * 60 * 5);
</script>
