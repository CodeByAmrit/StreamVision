<section class="p-4 sm:ml-64 dark:bg-gray-900 dark:text-white">
  <div class="w-full h-full mt-16">
    <!-- DVR Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
      <h2 class="text-xl sm:text-2xl font-semibold break-words">Location: <%= dvr.location_name %></h2>
      <a
        href="/camera/add/<%= dvr.id %>"
        class="inline-flex justify-center btn-gradient hover:bg-blue-700 text-white px-4 py-2 rounded text-sm whitespace-nowrap"
      >
        + Add Camera
      </a>
    </div>

    <!-- Camera Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% dvr.cameras.forEach((camera, index) => { %>
      <div
        class="max-w-sm bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700 overflow-hidden"
      >
        <!-- Video Player -->
        <video
          id="video<%= index + 1 %>"
          class="w-full h-48 object-cover bg-black"
          controls
          muted
          autoplay
          playsinline
          preload="none"
        ></video>

        <!-- Card Content -->
        <div class="p-5">
          <h5 class="mb-2 text-xl font-bold tracking-tight text-gray-900 dark:text-white">
            <%= camera.camera_name %>
          </h5>
          <p class="mb-3 font-normal text-sm text-gray-700 dark:text-gray-400 break-words">
            <!-- <span class="font-semibold">RTSP:</span> <%= camera.rtsp_url %> -->
          </p>
          <div class="flex justify-between space-x-2 mt-auto">
            <a
              href="/camera/edit/<%= camera.id %>"
              class="inline-flex justify-center flex-1 items-center px-3 py-1.5 text-xs sm:text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700"
            >
              Edit
            </a>
            <a
              href="/camera/delete/<%= camera.id %>"
              class="inline-flex justify-center flex-1 items-center px-3 py-1.5 text-xs sm:text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700"
            >
              Delete
            </a>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Add HLS.js -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest" nonce="<%= nonce %>"></script>

<script nonce="<%= nonce %>">
  const cameras = <%- JSON.stringify(dvr.cameras) %>;
  const dvrId = <%= dvr.id %>;

  async function tryLoadStream(camera, index, retries = 30, delay = 500) {
    const video = document.getElementById(`video${index + 1}`);

    try {
      const res = await fetch(`/api/public/camera/${camera.id}/hls`);
      if (!res.ok) throw new Error("API error");
      const data = await res.json();
      if (!data.hlsUrl) throw new Error("No HLS URL");
      
      const source = data.hlsUrl;

      if (Hls.isSupported()) {
        const hls = new Hls({ lowLatencyMode: true });
        hls.loadSource(source);
        hls.attachMedia(video);
        hls.on(Hls.Events.MANIFEST_PARSED, () => {
          video.play().catch(() => {});
        });
        hls.on(Hls.Events.ERROR, function (event, data) {
          if (data.fatal) {
            hls.destroy();
            if (retries > 0) {
              setTimeout(() => tryLoadStream(camera, index, retries - 1, delay), delay);
            }
          }
        });
      } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = source;
        video.addEventListener('loadedmetadata', () => {
          video.play().catch(() => {});
        });
      }
    } catch (err) {
      if (retries > 0) {
        setTimeout(() => tryLoadStream(camera, index, retries - 1, delay), delay);
      }
    }
  }

  function loadAllStreams() {
    cameras.forEach((camera, index) => {
      tryLoadStream(camera, index);
    });
  }

  setTimeout(() => {
    loadAllStreams();
  }, 1000);

  setInterval(() => {
    console.log("Refreshing streams...");
    loadAllStreams();
  }, 1000 * 60 * 5);
</script>
